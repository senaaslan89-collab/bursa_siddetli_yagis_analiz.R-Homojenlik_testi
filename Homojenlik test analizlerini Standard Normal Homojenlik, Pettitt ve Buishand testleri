# Madde:1 Homojenlik test analizlerini Standard Normal Homojenlik, Pettitt ve Buishand testleri
# ==============================================================================

# 1. ADIM: VERİYİ OKUMA VE TEMİZLEME
veri_ham <- read.csv(file.choose(), header = FALSE, sep = ";", check.names = FALSE)
colnames(veri_ham) <- veri_ham[2, ]
veri_temiz <- veri_ham[-c(1, 2), ]
veri_temiz[] <- lapply(veri_temiz, function(x) as.numeric(gsub(",", ".", x)))

colnames(veri_temiz)[1] <- "Yil"
sureler <- colnames(veri_temiz)[-1]

# 2. ADIM: SAF R İLE SNHT VE BUISHAND MATEMATİKSEL FONKSİYONLARININ TANIMLANMASI

snht_saf <- function(x) {
  n <- length(x)
  mean_x <- mean(x)
  sd_x <- sd(x)
  T_stat <- numeric(n - 1)
  for (i in 1:(n - 1)) {
    z1 <- mean(x[1:i])
    z2 <- mean(x[(i + 1):n])
    T_stat[i] <- i * ((z1 - mean_x) / sd_x)^2 + (n - i) * ((z2 - mean_x) / sd_x)^2
  }
  max_T <- max(T_stat)
  k_ind <- which.max(T_stat)
  # Yaklaşık p-değeri hesabı (Alexandersson simülasyon kritiği)
  p_val <- exp(-0.012 * max_T^2 - 0.23 * max_T)
  if(p_val > 1) p_val <- 1
  return(list(p.value = p_val, estimate = k_ind))
}

buishand_saf <- function(x) {
  n <- length(x)
  mean_x <- mean(x)
  sd_x <- sd(x)
  S_k <- numeric(n)
  S_k[1] <- x[1] - mean_x
  for(i in 2:n) S_k[i] <- S_k[i-1] + (x[i] - mean_x)
  S_k_star <- S_k / sd_x
  max_k <- which.max(abs(S_k_star))
  R_stat <- max(S_k) - min(S_k)
  V_stat <- R_stat / (sd_x * sqrt(n))
  # Yaklaşık p-değeri modellemesi
  p_val <- 1 - pnorm(V_stat * 1.2)
  if(p_val < 0) p_val <- 0
  return(list(p.value = p_val, estimate = max_k))
}

# 3. ADIM: TÜM SÜRELER İÇİN OTOMATİK DÖNGÜ VE TABLO OLUŞTURMA
# Sonuçları derli toplu bir tabloya dönüştürmek için boş bir dataframe açıyoruz
ozet_tablo <- data.frame(Sure=character(), Pettitt_p=numeric(), Pettitt_Yil=numeric(),
                         SNHT_p=numeric(), SNHT_Yil=numeric(), 
                         Buishand_p=numeric(), Buishand_Yil=numeric(), stringsAsFactors=FALSE)

for (sure in sureler) {
  ts_veri <- na.omit(veri_temiz[[sure]])
  yillar <- veri_temiz$Yil[!is.na(veri_temiz[[sure]])]
  
  if(length(ts_veri) > 10) {
    # 1. Pettitt Testi 
    p_res <- trend::pettitt.test(ts_veri)
    p_p <- round(p_res$p.value, 4)
    p_y <- yillar[p_res$estimate[[1]]]
    
    # 2. SNHT 
    s_res <- snht_saf(ts_veri)
    s_p <- round(s_res$p.value, 4)
    s_y <- yillar[s_res$estimate]
    
    # 3. Buishand 
    b_res <- buishand_saf(ts_veri)
    b_p <- round(b_res$p.value, 4)
    b_y <- yillar[b_res$estimate]
    
    # Tabloya satır ekleme
    ozet_tablo[nrow(ozet_tablo) + 1, ] <- c(sure, p_p, p_y, s_p, s_y, b_p, b_y)
  }
}

# 4. ADIM: SONUÇLARI EKRANA YAZDIRMA
cat("\n\n==================================================================\n")
cat("          BÜTÜN VERİ SETLERİ İÇİN HOMOJENLİK ÖZET TABLOSU\n")
cat("==================================================================\n")
print(ozet_tablo)
